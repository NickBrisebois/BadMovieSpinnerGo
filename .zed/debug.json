// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Attach Debugger",
    "adapter": "Delve",
    "request": "attach",
    "mode": "remote",
    "stopOnEntry": false,
    "tcp_connection": { "host": "127.0.0.1", "port": 2345 },
  },
  {
    "label": "Run API",
    "adapter": "Delve",
    "request": "launch",
    "mode": "debug",
    "program": "cmd/api/main.go",
    "envFile": ".env",
  },
]
