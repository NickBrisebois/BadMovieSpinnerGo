// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Run API",
    "adapter": "Delve",
    "request": "launch",
    "mode": "debug",
    "program": "cmd/api/main.go",
    "envFile": ".env",
  },
  {
    "label": "Run Spinner",
    "adapter": "Delve",
    "request": "launch",
    "mode": "debug",
    "program": "cmd/spinner/main.go",
    "envFile": ".env",
    "buildFlags": ["-tags=native", "-ldflags=-X 'main.apiHost=localhost' -X 'main.apiPort=8080'"],
  },
]
